# Example environment variables. Copy to .env for local overrides.
# The docker-compose.yml sets sane defaults for the local stack, so .env is
# optional for `docker compose up`.

# --- Backend ---
# SQLAlchemy URL (psycopg v3 driver). In Docker the host is the `db` service.
DATABASE_URL=postgresql+psycopg://claudeaws:claudeaws@db:5432/claudeaws
# AWS integration mode: mock (default, offline) or real (Phase 11+).
AWS_MODE=mock
# Comma-separated allowed CORS origins.
CORS_ORIGINS=http://localhost:5173
# JWT signing (PoC hard-coded auth). Use a random >=32-byte secret in any
# shared/deployed environment; the in-code default is a dev placeholder only.
JWT_SECRET=dev-secret-change-me-to-a-random-32B+-value
# JWT_EXPIRY_MINUTES=480

# --- Frontend (build/dev time) ---
# Where the Vite dev server proxies /api. In Docker this is the backend service.
VITE_API_PROXY_TARGET=http://backend:8000

# --- Database (postgres image) ---
POSTGRES_USER=claudeaws
POSTGRES_PASSWORD=claudeaws
POSTGRES_DB=claudeaws
